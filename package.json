{
  "name": "bluedesk",
  "version": "1.0.0",
  "description": "BlueDesk Desktop Application",
  "main": "main.js",
  "author": "BlueDesk",
  "license": "MIT",
  "build": {
    "appId": "com.bluedesk.app",
    "productName": "BlueDesk",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!node_modules/.cache",
      "!dist",
      "!out"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icons/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "BlueDesk"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "assets/icons/icon.icns",
      "category": "public.app-category.business"
    }
  },
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:mac:dmg": "electron-builder --mac dmg",
    "dist:mac:zip": "electron-builder --mac zip",
    "dist:linux": "electron-builder --linux"
  },
  "devDependencies": {
    "electron": "^27.1.3",
    "electron-builder": "^24.6.4"
  }
}